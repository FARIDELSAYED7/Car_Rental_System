## 8. DataStore.java — In-Memory Database
```java
import java.util.ArrayList;

// Static ArrayLists act as our "database"
public class DataStore {
    public static ArrayList<Car> cars = new ArrayList<>();
    public static ArrayList<User> users = new ArrayList<>();
    public static ArrayList<Rental> rentals = new ArrayList<>();
    public static ArrayList<Invoice> invoices = new ArrayList<>();

    private static int carIdCounter = 11;
    private static int rentalIdCounter = 1;
    private static int invoiceIdCounter = 1;
    private static int paymentIdCounter = 1;

    public static String generateCarId() {
        String id = "C" + String.format("%03d", carIdCounter); carIdCounter++; return id;
    }
    public static String generateRentalId() {
        String id = "R" + String.format("%03d", rentalIdCounter); rentalIdCounter++; return id;
    }
    public static String generateInvoiceId() {
        String id = "INV" + String.format("%03d", invoiceIdCounter); invoiceIdCounter++; return id;
    }
    public static String generatePaymentId() {
        String id = "PAY" + String.format("%03d", paymentIdCounter); paymentIdCounter++; return id;
    }

    public static void loadSampleData() {
        // Admins
        users.add(new Admin("U001", "admin1", "Ahmed Hassan", "ahmed@email.com", "admin123"));
        users.add(new Admin("U002", "admin2", "Sara Ali", "sara@email.com", "admin456"));
        // Customers
        users.add(new Customer("U003", "customer1", "Farid Elsayed", "farid@email.com", "cust123"));
        users.add(new Customer("U004", "customer2", "Nour Mohamed", "nour@email.com", "cust456"));
        users.add(new Customer("U005", "customer3", "Omar Khaled", "omar@email.com", "cust789"));
        // Cars
        cars.add(new Car("C001", "Toyota", "Camry", 2023, 50.0, true, "Sedan"));
        cars.add(new Car("C002", "BMW", "X5", 2024, 120.0, true, "SUV"));
        cars.add(new Car("C003", "Honda", "Civic", 2022, 40.0, true, "Sedan"));
        cars.add(new Car("C004", "Mercedes", "C-Class", 2024, 100.0, true, "Luxury"));
        cars.add(new Car("C005", "Ford", "Mustang", 2023, 90.0, true, "Sports"));
        cars.add(new Car("C006", "Toyota", "RAV4", 2023, 65.0, true, "SUV"));
        cars.add(new Car("C007", "Hyundai", "Elantra", 2022, 35.0, true, "Economy"));
        cars.add(new Car("C008", "Kia", "Sportage", 2024, 55.0, true, "SUV"));
        cars.add(new Car("C009", "Nissan", "Altima", 2023, 45.0, true, "Sedan"));
        cars.add(new Car("C010", "Chevrolet", "Tahoe", 2024, 110.0, true, "SUV"));
    }

    public static User findUser(String username, String password) {
        for (int i = 0; i < users.size(); i++) {
            User user = users.get(i);
            if (user.getUsername().equals(username) && user.getPassword().equals(password)) {
                return user;
            }
        }
        return null;
    }

    public static Car findCarById(String carId) {
        for (int i = 0; i < cars.size(); i++) {
            if (cars.get(i).getCarId().equals(carId)) { return cars.get(i); }
        }
        return null;
    }

    public static ArrayList<Car> getAvailableCars() {
        ArrayList<Car> available = new ArrayList<>();
        for (int i = 0; i < cars.size(); i++) {
            if (cars.get(i).isAvailable()) { available.add(cars.get(i)); }
        }
        return available;
    }

    public static ArrayList<Customer> getAllCustomers() {
        ArrayList<Customer> customers = new ArrayList<>();
        for (int i = 0; i < users.size(); i++) {
            if (users.get(i) instanceof Customer) {
                customers.add((Customer) users.get(i));
            }
        }
        return customers;
    }
}
```
